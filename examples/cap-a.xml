<PGSN>
    <!-- per-component evidence-goal builders; {c} is filled from the param -->
    <def name="mkTestDoc" as="template">
        <param name="c" positional="true"/>
        <apply template="evidence_as_goal">
            <arg><Evidence>Test doc for {c}</Evidence></arg>
        </apply>
    </def>

    <def name="mkTestResource" as="template">
        <param name="c" positional="true"/>
        <apply template="evidence_as_goal">
            <arg><Evidence>Test resources for {c}</Evidence></arg>
        </apply>
    </def>

    <def name="gd3" as="template">
        <param name="xs" positional="true"/>
        <def name="testDocs">
            <apply template="map_term"><arg var="mkTestDoc"/><arg var="xs"/></apply>
        </def>
        <def name="testResources">
            <apply template="map_term"><arg var="mkTestResource"/><arg var="xs"/></apply>
        </def>
        <def name="evidences">
            <apply template="cons">
                <arg><apply template="evidence_as_goal"><arg><Evidence>E3.1...</Evidence></arg></apply></arg>
                <arg><apply template="concat"><arg var="testDocs"/><arg var="testResources"/></apply></arg>
            </apply>
        </def>
        <Goal>
            <description>GD3: Security test is ...</description>
            <Context>N.D. devel. info. ...</Context>
            <supportedBy><apply template="immediate"><arg var="evidences"/></apply></supportedBy>
        </Goal>
    </def>

    <apply template="gd3">
        <arg><ol><li>C1</li><li>C2</li><li>C3</li></ol></arg>
    </apply>
</PGSN>