<?xml version="1.0" ?>
<?xml-model href="../PGSN.rng" type="application/xml"?>
<PGSN>

    <!-- ==============================
         params: variables received from outside
         ============================== -->

    <!-- this PGSN receives A1 from the caller -->
    <param name="A1" instanceOf="Assumption"/>

    <!-- with a default value -->
    <param name="threshold">100</param>


    <!-- ==============================
         import
         ============================== -->

    <!-- single import -->
    <from file="security.pgsn" import="secureGoal" as="G1"/>

    <!-- multiple imports using child elements
    <from file="evidence.pgsn">
        <import name="auditEvidence"/>
        <import name="testReport" as="TR"/>
    </from>
    -->

    <!-- import with parameters passed to the module
    <from file="other.pgsn">
        <import name="someGoal" as="G2"/>
        <arg name="A1" var="A1"/>
        <arg name="threshold" var="threshold"/>
    </from>
    -->


    <!-- ==============================
         def: bind a name to a value
         ============================== -->

    <!-- simple binding -->
    <def name="x">expr</def>

    <!-- variable reference -->
    <def name="varExample"><var name="x"/></def>

    <!-- anonymous function (template): expr1 is the default value, expr2 is the body -->
    <def name="f">
        <template>
            <param name="arg1">expr1</param>
            <param name="arg2"/>
            expr2
        </template>
    </def>

    <!-- template application (apply): apply f to arg1 and arg2 -->
    <def name="result">
        <apply>
            <var name="f"/>
            <arg name="arg1">expr1</arg>
            <arg name="arg2">expr2</arg>
        </apply>
    </def>

    <!-- class definition: inherits from klass, with attributes and a method -->
    <def name="ClassB">
        <class>
            <inherit>klass</inherit>
            <attribute name="attr1">C</attribute>
            <attribute name="attr2"/>
            <method name="m">
                <param name="param1">expr</param>
                <param name="param2"/>
                expr
            </method>
        </class>
    </def>

    <!-- object instantiation: an instance of Ubuntu -->
    <def name="ubuntu">
        <object>
            <instanceOf>Ubuntu</instanceOf>
            <attribute name="version">20.0</attribute>
        </object>
    </def>

    <!-- attribute access -->
    <def name="ver">
        <get name="version"><var name="ubuntu"/></get>
    </def>

    <!-- method invocation: call method m on ubuntu -->
    <def name="sent">
        <send name="m"><var name="ubuntu"/>
            <arg name="arg1">expr1</arg>
            <arg name="arg2">expr2</arg>
        </send>
    </def>

    <!-- local definitions -->
    <def name="localExample">
        <div>
            <def name="x">expr1</def>
            <def name="y">expr2</def>
            expr
        </div>
    </def>

    <!-- data type: set (unordered) -->
    <def name="aSet">
        <ul>
            <li>item1</li>
            <li>item2</li>
        </ul>
    </def>

    <!-- data type: list (ordered) -->
    <def name="aList">
        <ol>
            <li>item1</li>
            <li>item2</li>
        </ol>
    </def>

    <!-- data type: dictionary -->
    <def name="aDict">
        <dl>
            <dt>key1</dt><dd>value1</dd>
            <dt key="key2"/><dd>value2</dd>
        </dl>
    </def>

    <!-- extending a GSN node via class inheritance -->
    <def name="GoalWithURL">
        <class>
            <inherit>Goal</inherit>
            <attribute name="URL"/>
        </class>
    </def>

    <!-- GSN: a Goal supported by Evidence -->
    <def name="evidenceGoal" as="Goal">
        <description>X is secure</description>
        <Evidence>operational track record</Evidence>
    </def>

    <!-- GSN: a Strategy referencing sub-goals via a variable -->
    <def name="mainStrategy" as="Strategy">
        verified through testing and review
        <subGoals>
            <ul>
                <li var="evidenceGoal"/>
                <li var="G1"/>
            </ul>
        </subGoals>
    </def>

    <!-- shorthand notation (expanded by preprocessor):
         <tag var="x"/>
         expands to
         <tag><var name="x"/></tag>

         similarly:
         <def name="x" as="tag">...</def>
         expands to
         <def name="x"><tag>...</tag></def>
    -->


    <!-- ==============================
         final value: the top-level Goal
         ============================== -->

    <Goal>
        <description>X is secure</description>
        <Context>certified under standard XXXX</Context>
        <Context><get name="version"><var name="ubuntu"/></get></Context>
        <Assumption>no zero-day attacks<var name="A1"/></Assumption>
        <Strategy var="mainStrategy"/>
    </Goal>

</PGSN>